# ============================================================================
# CONFIGURAÇÕES DE AUTENTICAÇÃO WEB
# ============================================================================
WEB_USERNAME=admin
WEB_PASSWORD=change-this-password
SECRET_KEY=change-this-super-secret-key-in-production

# ============================================================================
# CONFIGURAÇÕES SSH (Sistema Original)
# ============================================================================
SSH_HOST=192.168.1.1
SSH_PORT=22
SSH_USERNAME=admin
SSH_PASSWORD=your-device-password

# ============================================================================
# CONFIGURAÇÕES SNMP (Sistema Híbrido) 
# ============================================================================
# IMPORTANTE: Altere o HUAWEI_SNMP_HOST para o IP real do seu equipamento!
HUAWEI_SNMP_HOST=192.168.1.1
HUAWEI_SNMP_PORT=161
HUAWEI_SNMP_COMMUNITY=public

# ============================================================================
# CONFIGURAÇÕES REDIS (Cache Avançado)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_DASHBOARD=60
REDIS_TTL_DETAILS=300
REDIS_TTL_INTERFACES=180

# ============================================================================
# CONFIGURAÇÕES DE TIMEOUT E PERFORMANCE
# ============================================================================
SNMP_TIMEOUT=5
SNMP_RETRIES=3
CACHE_DEFAULT_TTL=60
COLLECTION_INTERVAL=30

# ============================================================================
# CONFIGURAÇÕES DE LOG
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=ne8000_monitor.log

# ============================================================================
# CONFIGURAÇÕES DO SISTEMA
# ============================================================================
DEBUG=False
ENVIRONMENT=production
MAX_HISTORY_POINTS=288 