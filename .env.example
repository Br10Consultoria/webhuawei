# ============================================================
# NE8000 Network Manager — Configuracao de Ambiente
# ============================================================

# --- Acesso Web ---
WEB_USERNAME=admin
WEB_PASSWORD=senha-segura-aqui
SECRET_KEY=chave-aleatoria-longa-e-segura-aqui

# --- Autenticacao 2FA (TOTP) ---
# Para ativar: defina TOTP_ENABLED=true e configure TOTP_SECRET
# Para gerar o TOTP_SECRET: acesse /setup-2fa apos o primeiro login
TOTP_ENABLED=false
TOTP_SECRET=
TOTP_ISSUER=NE8000 Monitor

# --- Conexao com o Roteador Huawei NE8000 ---
ROUTER_HOST=10.0.0.1
ROUTER_PROTOCOL=ssh
ROUTER_SSH_PORT=22
ROUTER_USERNAME=admin
ROUTER_PASSWORD=senha-do-roteador

# --- Configuracoes Opcionais ---
LOG_LEVEL=INFO
CACHE_TTL=30
