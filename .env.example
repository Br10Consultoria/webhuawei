# ============================================================================
# CONFIGURAÇÕES DE AUTENTICAÇÃO WEB
# ============================================================================
WEB_USERNAME=admin
WEB_PASSWORD=change-this-password
SECRET_KEY=change-this-super-secret-key-in-production

# ============================================================================
# CONFIGURAÇÕES DE CONEXÃO COM O ROTEADOR (SSH ou Telnet)
# ============================================================================
# IP ou hostname do roteador Huawei NE8000
ROUTER_HOST=192.168.1.1

# Protocolo de conexão: ssh ou telnet
ROUTER_PROTOCOL=ssh

# Porta SSH (padrão: 22)
ROUTER_SSH_PORT=22

# Porta Telnet (padrão: 23) — usada quando ROUTER_PROTOCOL=telnet
ROUTER_TELNET_PORT=23

# Credenciais de acesso ao roteador
ROUTER_USERNAME=admin
ROUTER_PASSWORD=your-device-password

# ============================================================================
# CONFIGURAÇÕES SNMP (Sistema Híbrido — opcional)
# ============================================================================
HUAWEI_SNMP_HOST=192.168.1.1
HUAWEI_SNMP_PORT=161
HUAWEI_SNMP_COMMUNITY=public

# ============================================================================
# CONFIGURAÇÕES REDIS (Cache Avançado)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_DASHBOARD=60
REDIS_TTL_DETAILS=300
REDIS_TTL_INTERFACES=180

# ============================================================================
# CONFIGURAÇÕES DE TIMEOUT E PERFORMANCE
# ============================================================================
SNMP_TIMEOUT=5
SNMP_RETRIES=3
CACHE_DEFAULT_TTL=60
COLLECTION_INTERVAL=30

# ============================================================================
# CONFIGURAÇÕES DE LOG
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=ne8000_monitor.log

# ============================================================================
# CONFIGURAÇÕES DO SISTEMA
# ============================================================================
DEBUG=False
ENVIRONMENT=production
MAX_HISTORY_POINTS=288
